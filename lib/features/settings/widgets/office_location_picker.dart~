import 'package:admin_attendance/core/theme/app_theme.dart';
import 'package:admin_attendance/view_model/admin_cubit.dart';
import 'package:flutter/material.dart';
import 'package:google_maps_flutter/google_maps_flutter.dart';

/// Full-screen polygon editor with auto-location detection.
class OfficePolygonPicker extends StatefulWidget {
  final List<LatLng> initialPolygon;

  const OfficePolygonPicker({
    super.key,
    required this.initialPolygon,
  });

  @override
  State<OfficePolygonPicker> createState() => _OfficePolygonPickerState();
}

class _OfficePolygonPickerState extends State<OfficePolygonPicker> {
  late GoogleMapController _mapController;
  late List<LatLng> _points;
  LatLng? _currentUserLocation;
  double _currentZoom = 16;

  static const LatLng _defaultCenter = LatLng(24.7136, 46.6753);

  @override
  void initState() {
    super.initState();
    _points = List<LatLng>.from(widget.initialPolygon);

    // Automatically fetch location and center map when the picker opens
    // WidgetsBinding.instance.addPostFrameCallback((_) {
    //   _initLocation();
    // });
  }

  Future<void> _initLocation() async {
    final cubit = AdminCubit.get(context);
    final location = await cubit.getCurrentLocation();
    if (location != null) {
      setState(() => _currentUserLocation = location);
      _mapController.animateCamera(
        CameraUpdate.newLatLngZoom(location, 16),
      );
    }
  }

  // ── Map interactions ────────────────────────────────────────────────────────

  void _onMapTap(LatLng position) {
    setState(() => _points.add(position));
  }

  void _removeLastPoint() {
    if (_points.isNotEmpty) setState(() => _points.removeLast());
  }

  void _clearAll() {
    if (_points.isNotEmpty) setState(() => _points.clear());
  }

  Future<void> _zoomIn() async {
    _currentZoom = (_currentZoom + 1).clamp(1.0, 21.0);
    await _mapController.animateCamera(CameraUpdate.zoomIn());
  }

  Future<void> _zoomOut() async {
    _currentZoom = (_currentZoom - 1).clamp(1.0, 21.0);
    await _mapController.animateCamera(CameraUpdate.zoomOut());
  }

  // ── Helpers ─────────────────────────────────────────────────────────────────

  LatLng get _initialCameraTarget =>
      _points.isNotEmpty ? _points.first : _defaultCenter;

  Set<Polygon> get _polygons => _points.length >= 3
      ? {
    Polygon(
      polygonId: const PolygonId('drawing'),
      points: _points,
      fillColor: AppColors.primaryColor.withOpacity(0.2),
      strokeColor: AppColors.primaryColor,
      strokeWidth: 2,
    ),
  }
      : {};

  Set<Polyline> get _polylines => _points.length >= 2
      ? {
    Polyline(
      polylineId: const PolylineId('preview_line'),
      points: _points,
      color: AppColors.primaryColor,
      width: 2,
      patterns: [PatternItem.dash(12), PatternItem.gap(6)],
    ),
  }
      : {};
  Set<Circle> get _circles {
    return _points.asMap().entries.map((e) {
      return Circle(
        circleId: CircleId('point_${e.key}'),
        center: e.value,
        radius: 0.9, // Small radius in meters
        fillColor: Colors.white,
        strokeColor: AppColors.primaryColor,
        strokeWidth: 8,
        zIndex: 3,
      );
    }).toSet();
  }
  Set<Marker> get _markers {
    // We only return the user's location marker here.
    // The polygon points are already handled by the _circles getter.
    if (_currentUserLocation != null) {
      return {
        Marker(
          markerId: const MarkerId('current_user_loc'),
          position: _currentUserLocation!,
          // You can change hueGreen to hueAzure, hueBlue, etc.
          // or use a custom asset icon here.
          icon: BitmapDescriptor.defaultMarkerWithHue(BitmapDescriptor.hueAzure),
          infoWindow: const InfoWindow(title: 'You are here'),
          zIndex: 10, // Higher zIndex so it stays above the circles/polygon
        ),
      };
    }
    return {};
  }
  // Set<Marker> get _markers {
  //   // 1. Map the boundary points (Azure Pins)
  //   final Set<Marker> allMarkers = _points.asMap().entries.map((e) {
  //     return Marker(
  //       markerId: MarkerId('pt_${e.key}'),
  //       position: e.value,
  //       icon: BitmapDescriptor.defaultMarkerWithHue(BitmapDescriptor.hueAzure),
  //       infoWindow: InfoWindow(title: 'Point ${e.key + 1}'),
  //     );
  //   }).toSet();
  //
  //   // 2. Add the User's Current Location (Green Marker)
  //   if (_currentUserLocation != null) {
  //     allMarkers.add(
  //       Marker(
  //         markerId: const MarkerId('current_user_loc'),
  //         position: _currentUserLocation!,
  //         icon: BitmapDescriptor.defaultMarkerWithHue(BitmapDescriptor.hueGreen),
  //         infoWindow: const InfoWindow(title: 'You are here'),
  //         zIndex: 2, // Ensure it stays on top
  //       ),
  //     );
  //   }
  //
  //   return allMarkers;
  // }

  // ── UI ───────────────────────────────────────────────────────────────────────

  @override
  Widget build(BuildContext context) {
    final bool canConfirm = _points.length >= 3;
    const double toolbarHeight = 80.0;
    const double zoomBtnSize = 36.0;

    return ClipRRect(
      borderRadius: BorderRadius.circular(16),
      child: Stack(
        children: [
          GoogleMap(
            onMapCreated: (c) => _mapController = c,
            initialCameraPosition: CameraPosition(
              target: _initialCameraTarget,
              zoom: _currentZoom,
            ),
            onTap: _onMapTap,
            myLocationEnabled: true, // Keep the native blue dot too
            myLocationButtonEnabled: false,
            zoomControlsEnabled: false,
            zoomGesturesEnabled: true,
            polygons: _polygons,
            polylines: _polylines,
            markers: _markers,
            circles: _circles,
          ),

          // Instruction banner
          Positioned(
            top: 12,
            left: 12,
            right: 60,
            child: Container(
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
              decoration: BoxDecoration(
                color: Colors.white.withOpacity(0.92),
                borderRadius: BorderRadius.circular(10),
                boxShadow: [
                  BoxShadow(
                    color: Colors.black.withOpacity(0.08),
                    blurRadius: 6,
                    offset: const Offset(0, 2),
                  ),
                ],
              ),
              child: Text(
                _points.isEmpty
                    ? 'Tap the map to add boundary points'
                    : '${_points.length} points added',
                style: const TextStyle(fontSize: 12, color: Colors.black87),
              ),
            ),
          ),

          // Re-center button
          Positioned(
            top: 12,
            right: 12,
            child: _MapIconButton(
              heroTag: 'loc_btn',
              icon: Icons.my_location,
              iconColor: AppColors.primaryColor,
              size: zoomBtnSize,
              onPressed: _initLocation,
              tooltip: 'Center on me',
            ),
          ),

          // Zoom controls
          Positioned(
            right: 12,
            bottom: toolbarHeight + 12,
            child: Container(
              decoration: BoxDecoration(
                color: Colors.white,
                borderRadius: BorderRadius.circular(8),
                boxShadow: [
                  BoxShadow(
                    color: Colors.black.withOpacity(0.12),
                    blurRadius: 6,
                    offset: const Offset(0, 2),
                  ),
                ],
              ),
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  _ZoomButton(icon: Icons.add, onPressed: _zoomIn),
                  Divider(height: 1, thickness: 1, color: Colors.grey.shade300, indent: 6, endIndent: 6),
                  _ZoomButton(icon: Icons.remove, onPressed: _zoomOut),
                ],
              ),
            ),
          ),

          // Toolbar
          Positioned(
            bottom: 20,
            left: 16,
            right: 16,
            child: Row(
              children: [
                _ToolbarButton(
                  heroTag: 'undo_btn',
                  icon: Icons.undo_rounded,
                  color: Colors.orange,
                  onPressed: _removeLastPoint,
                ),
                const SizedBox(width: 8),
                _ToolbarButton(
                  heroTag: 'clear_btn',
                  icon: Icons.delete_outline_rounded,
                  color: Colors.red,
                  onPressed: _clearAll,
                ),
                const Spacer(),
                ElevatedButton.icon(
                  onPressed: canConfirm ? () => Navigator.of(context).pop(_points) : null,
                  style: ElevatedButton.styleFrom(
                    backgroundColor: AppColors.primaryColor,
                    foregroundColor: Colors.white,
                    disabledBackgroundColor: Colors.grey.shade300,
                    padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 12),
                    shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(10)),
                  ),
                  icon: const Icon(Icons.check_rounded),
                  label: Text(canConfirm ? 'Confirm' : 'Need 3+ points'),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }
}

class _ZoomButton extends StatelessWidget {
  final IconData icon;
  final VoidCallback onPressed;
  const _ZoomButton({required this.icon, required this.onPressed});

  @override
  Widget build(BuildContext context) {
    return InkWell(
      onTap: onPressed,
      child: SizedBox(width: 36, height: 36, child: Icon(icon, size: 20, color: Colors.black87)),
    );
  }
}

class _MapIconButton extends StatelessWidget {
  final String heroTag;
  final IconData icon;
  final Color iconColor;
  final double size;
  final VoidCallback onPressed;
  final String tooltip;

  const _MapIconButton({
    required this.heroTag, required this.icon, required this.iconColor,
    required this.size, required this.onPressed, required this.tooltip,
  });

  @override
  Widget build(BuildContext context) {
    return Material(
      color: Colors.white,
      elevation: 3,
      borderRadius: BorderRadius.circular(8),
      child: InkWell(
        onTap: onPressed,
        borderRadius: BorderRadius.circular(8),
        child: SizedBox(width: size, height: size, child: Icon(icon, color: iconColor, size: 20)),
      ),
    );
  }
}

class _ToolbarButton extends StatelessWidget {
  final String heroTag;
  final IconData icon;
  final Color color;
  final VoidCallback onPressed;

  const _ToolbarButton({
    required this.heroTag, required this.icon,
    required this.color, required this.onPressed,
  });

  @override
  Widget build(BuildContext context) {
    return FloatingActionButton.small(
      heroTag: heroTag,
      onPressed: onPressed,
      backgroundColor: Colors.white,
      elevation: 3,
      child: Icon(icon, color: color),
    );
  }
}